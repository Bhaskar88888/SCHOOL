generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String               @id @default(uuid())
  name                     String
  email                    String               @unique
  password                 String
  role                     String               @default("student")
  phone                    String
  employeeId               String?              @unique
  department               String?
  designation              String?
  isActive                 Boolean              @default(true)
  profilePhoto             String?
  linkedStudentIds         Json?
  employmentType           String?
  dateOfBirth              DateTime?
  bloodGroup               String?
  highestQualification     String?
  experienceYears          Int?
  pan                      String?
  aadhaar                  String?
  joiningDate              DateTime?
  emergencyContactName     String?
  emergencyContactPhone    String?
  staffAddress             Json?
  basicPay                 Float?
  hra                      Float?
  da                       Float?
  conveyance               Float?
  pfDeduction              Float?
  esiDeduction             Float?
  bankName                 String?
  accountNumber            String?
  ifscCode                 String?
  casualLeaveBalance       Int                  @default(12)
  earnedLeaveBalance       Int                  @default(15)
  sickLeaveBalance         Int                  @default(10)
  failedLoginAttempts      Int                  @default(0)
  lockUntil                DateTime?
  passwordChangeRequired   Boolean              @default(false)
  passwordResetTokenHash   String?
  passwordResetExpiresAt   DateTime?
  hrNotes                  String?              @db.Text
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt
  students                 Student[]            @relation("ParentStudent")
  classesTaught            Class[]              @relation("ClassTeacher")
  subjectsTaught           ClassSubject[]       @relation("SubjectTeacher")
  userStudents             Student[]            @relation("UserAccount")
  collectedFees            FeePayment[]         @relation("FeeCollector")
  attendances              Attendance[]
  leaveRequests            Leave[]              @relation("LeaveRequests")
  leaveReviews             Leave[]              @relation("LeaveReviews")
  remarks                  Remark[]
  complaintsRaised         Complaint[]          @relation("ComplaintSource")
  complaintsReceived       Complaint[]          @relation("ComplaintTarget")
  homeworks                Homework[]
  noticesCreated           Notice[]             @relation("NoticeCreator")
  notificationsReceived    Notification[]       @relation("NotificationRecipient")
  notificationsSent        Notification[]       @relation("NotificationSender")
  driverVehicles           TransportVehicle[]   @relation("VehicleDriver")
  conductorVehicles        TransportVehicle[]   @relation("VehicleConductor")
  driverRoutes             BusRoute[]           @relation("RouteDriver")
  conductorRoutes          BusRoute[]           @relation("RouteConductor")
  transportAttendanceMarks TransportAttendance[] @relation("TransportMarkedBy")
  salaryStructures         SalaryStructure[]    @relation("SalaryStructureStaff")
  payrolls                 Payroll[]            @relation("PayrollStaff")
  staffAttendances         StaffAttendance[]    @relation("StaffAttendanceStaff")
  auditLogs                AuditLog[]           @relation("AuditUser")
  chatbotLogs              ChatbotLog[]         @relation("ChatbotUser")
  canteenSales             CanteenSale[]        @relation("CanteenSoldBy")
}

model Student {
  id                     String               @id @default(uuid())
  userId                 String               @unique
  user                   User                 @relation("UserAccount", fields: [userId], references: [id])
  name                   String
  studentId              String?              @unique
  admissionNo            String               @unique
  classId                String
  class                  Class                @relation(fields: [classId], references: [id])
  parentPhone            String
  parentEmail            String?
  parentUserId           String?
  parentUser             User?                @relation("ParentStudent", fields: [parentUserId], references: [id])
  dob                    DateTime
  address                String?
  admissionDate          DateTime             @default(now())
  gender                 String
  aadhaar                String?
  apaarId                String?
  pen                    String?
  enrollmentNo           String?
  section                String?
  rollNumber             String?
  academicYear           String?
  bloodGroup             String?
  nationality            String?
  religion               String?
  category               String?
  motherTongue           String?
  previousSchool         String?
  fatherName             String?
  fatherOccupation       String?
  motherName             String?
  motherPhone            String?
  motherOccupation       String?
  guardianName           String?
  guardianRelation       String?
  guardianPhone          String?
  emergencyContactName   String?
  emergencyContactPhone  String?
  structuredAddress      Json?
  transportRequired      Boolean              @default(false)
  hostelRequired         Boolean              @default(false)
  medicalConditions      String?
  allergies              String?
  admissionNotes         String?              @db.Text
  tcFileUrl              String?
  birthCertFileUrl       String?
  canteenBalance         Float                @default(0)
  rfidTagHex             String?              @unique
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  feePayments            FeePayment[]
  examResults            ExamResult[]
  attendances            Attendance[]
  remarks                Remark[]
  complaints             Complaint[]
  notices                Notice[]
  libraryTransactions    LibraryTransaction[]
  transportAttendances   TransportAttendance[]
  transportVehicles      TransportVehicle[]   @relation("VehicleStudents")
  hostelAllocations      HostelAllocation[]
}

model Class {
  id              String         @id @default(uuid())
  name            String
  section         String
  sections        Json?
  capacity        Int            @default(60)
  academicYear    String?
  classTeacherId  String?
  classTeacher    User?          @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  subjects        ClassSubject[]
  students        Student[]
  feeStructures   FeeStructure[]
  exams           Exam[]
  attendances     Attendance[]
  complaints      Complaint[]
  homeworks       Homework[]
  routines        Routine[]
  notices         Notice[]
}

model ClassSubject {
  id             String  @id @default(uuid())
  name           String?
  subject        String?
  periodsPerWeek Int     @default(4)
  classId        String
  class          Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherId      String?
  teacher        User?   @relation("SubjectTeacher", fields: [teacherId], references: [id])
}

model FeeStructure {
  id           String       @id @default(uuid())
  classId      String
  class        Class        @relation(fields: [classId], references: [id])
  feeType      String
  amount       Float
  dueDate      DateTime?
  term         String       @default("Annual")
  description  String?      @db.Text
  lateFee      Float        @default(0)
  type         String?
  academicYear String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  payments     FeePayment[]
}

model FeePayment {
  id             String        @id @default(uuid())
  studentId      String
  student        Student       @relation(fields: [studentId], references: [id])
  feeStructureId String?
  feeStructure   FeeStructure? @relation(fields: [feeStructureId], references: [id])
  amountPaid     Float
  originalAmount Float?
  discount       Float         @default(0)
  paymentDate    DateTime      @default(now())
  date           DateTime      @default(now())
  receiptNo      String        @unique
  collectedById  String
  collectedBy    User          @relation("FeeCollector", fields: [collectedById], references: [id])
  paymentMode    String
  remarks        String?       @db.Text
  feeType        String        @default("General")
  academicYear   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([studentId, paymentDate])
}

model Exam {
  id           String       @id @default(uuid())
  name         String
  examType     String       @default("General")
  classId      String
  class        Class        @relation(fields: [classId], references: [id])
  subject      String
  date         DateTime
  time         String
  startTime    String?
  endTime      String?
  roomNumber   String?
  instructions String?      @db.Text
  totalMarks   Float        @default(100)
  passingMarks Float        @default(35)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  results      ExamResult[]
}

model ExamResult {
  id            String   @id @default(uuid())
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  marksObtained Float
  totalMarks    Float    @default(100)
  grade         String?
  remarks       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([examId, studentId])
}

model Attendance {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  date      DateTime
  status    String
  smsSent   Boolean  @default(false)
  subject   String?
  remarks   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, classId, date, subject])
}

model Leave {
  id           String   @id @default(uuid())
  staffId      String
  staff        User     @relation("LeaveRequests", fields: [staffId], references: [id])
  type         String
  fromDate     DateTime
  toDate       DateTime
  reason       String   @db.Text
  status       String   @default("pending")
  reviewedById String?
  reviewedBy   User?    @relation("LeaveReviews", fields: [reviewedById], references: [id])
  reviewNote   String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Remark {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacherId String
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  remark    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Complaint {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation("ComplaintSource", fields: [userId], references: [id])
  targetUserId   String?
  targetUser     User?    @relation("ComplaintTarget", fields: [targetUserId], references: [id])
  type           String   @default("general")
  studentId      String?
  student        Student? @relation(fields: [studentId], references: [id])
  classId        String?
  class          Class?   @relation(fields: [classId], references: [id])
  subject        String
  description    String   @db.Text
  status         String   @default("open")
  raisedByRole   String
  assignedToRole String?
  resolutionNote String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Homework {
  id          String   @id @default(uuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject     String
  title       String
  description String   @db.Text
  dueDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Routine {
  id        String   @id @default(uuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  timetable Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notice {
  id               String   @id @default(uuid())
  title            String
  content          String   @db.Text
  audience         Json
  createdById      String
  createdBy        User     @relation("NoticeCreator", fields: [createdById], references: [id])
  relatedClassId   String?
  relatedClass     Class?   @relation(fields: [relatedClassId], references: [id])
  relatedStudentId String?
  relatedStudent   Student? @relation(fields: [relatedStudentId], references: [id])
  priority         String   @default("normal")
  published        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Notification {
  id              String   @id @default(uuid())
  recipientId     String
  recipient       User     @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  senderId        String?
  sender          User?    @relation("NotificationSender", fields: [senderId], references: [id])
  title           String
  message         String   @db.Text
  type            String   @default("general")
  read            Boolean  @default(false)
  relatedEntityId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StaffAttendance {
  id        String   @id @default(uuid())
  staffId   String
  staff     User     @relation("StaffAttendanceStaff", fields: [staffId], references: [id], onDelete: Cascade)
  date      DateTime
  status    String
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, date])
}

model SalaryStructure {
  id               String   @id @default(uuid())
  staffId          String
  staff            User     @relation("SalaryStructureStaff", fields: [staffId], references: [id], onDelete: Cascade)
  basicSalary      Float
  hra              Float    @default(0)
  da               Float    @default(0)
  conveyance       Float    @default(0)
  medicalAllowance Float    @default(0)
  specialAllowance Float    @default(0)
  pfDeduction      Float    @default(0)
  taxDeduction     Float    @default(0)
  otherDeductions  Float    @default(0)
  effectiveFrom    DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([staffId, effectiveFrom])
}

model Payroll {
  id               String   @id @default(uuid())
  staffId          String
  staff            User     @relation("PayrollStaff", fields: [staffId], references: [id], onDelete: Cascade)
  month            Int
  year             Int
  basicSalary      Float
  hra              Float    @default(0)
  da               Float    @default(0)
  conveyance       Float    @default(0)
  medicalAllowance Float    @default(0)
  specialAllowance Float    @default(0)
  totalEarnings    Float    @default(0)
  pfDeduction      Float    @default(0)
  taxDeduction     Float    @default(0)
  otherDeductions  Float    @default(0)
  totalDeductions  Float    @default(0)
  netPay           Float    @default(0)
  generatedDate    DateTime @default(now())
  isPaid           Boolean  @default(false)
  paidOn           DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([staffId, month, year])
}

model LibraryBook {
  id              String               @id @default(uuid())
  isbn            String?              @unique
  title           String
  author          String               @default("Unknown Author")
  coverImageUrl   String?
  totalCopies     Int                  @default(1)
  availableCopies Int                  @default(1)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  transactions    LibraryTransaction[]
}

model LibraryTransaction {
  id         String      @id @default(uuid())
  studentId  String
  student    Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  bookId     String
  book       LibraryBook @relation(fields: [bookId], references: [id], onDelete: Cascade)
  issueDate  DateTime    @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     String      @default("BORROWED")
  fineAmount Float       @default(0)
  remarks    String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model TransportVehicle {
  id                  String                @id @default(uuid())
  busNumber           String                @unique
  numberPlate         String                @unique
  driverId            String?
  driver              User?                 @relation("VehicleDriver", fields: [driverId], references: [id])
  conductorId         String?
  conductor           User?                 @relation("VehicleConductor", fields: [conductorId], references: [id])
  route               String
  capacity            Int                   @default(40)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  students            Student[]             @relation("VehicleStudents")
  transportAttendance TransportAttendance[]
  busRoutes           BusRoute[]            @relation("RouteVehicle")
}

model TransportAttendance {
  id        String            @id @default(uuid())
  busId      String
  bus        TransportVehicle @relation(fields: [busId], references: [id], onDelete: Cascade)
  studentId  String
  student    Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date       String
  status     String
  markedById String?
  markedBy   User?            @relation("TransportMarkedBy", fields: [markedById], references: [id])
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([busId, studentId, date])
}

model BusRoute {
  id              String            @id @default(uuid())
  routeName       String
  routeCode       String            @unique
  routeNumber     String
  vehicleId       String?
  vehicle         TransportVehicle? @relation("RouteVehicle", fields: [vehicleId], references: [id])
  driverId        String?
  driver          User?             @relation("RouteDriver", fields: [driverId], references: [id])
  conductorId     String?
  conductor       User?             @relation("RouteConductor", fields: [conductorId], references: [id])
  totalDistance   Float             @default(0)
  totalDuration   Float             @default(0)
  departureTime   String
  returnTime      String?
  vehicleType     String            @default("Non-AC Bus")
  capacity        Int               @default(50)
  activeStudents  Int               @default(0)
  feePerStudent   Float             @default(0)
  totalCollection Float             @default(0)
  isActive        Boolean           @default(true)
  description     String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  stops           BusStop[]
}

model BusStop {
  id            String   @id @default(uuid())
  routeId       String
  route         BusRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  stopName      String
  stopCode      String?
  sequence      Int
  arrivalTime   String?
  departureTime String?
  distance      Float    @default(0)
  latitude      Float?
  longitude     Float?
  landmark      String?
  isPickup      Boolean  @default(true)
  isDrop        Boolean  @default(true)

  @@unique([routeId, sequence])
}

model HostelRoomType {
  id           String               @id @default(uuid())
  name         String               @unique
  code         String               @default("")
  occupancy    Int
  genderPolicy String               @default("mixed")
  defaultFee   Float                @default(0)
  amenities    Json?
  description  String?              @default("")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  rooms        HostelRoom[]
  feePlans     HostelFeeStructure[]
  allocations  HostelAllocation[]
}

model HostelRoom {
  id            String             @id @default(uuid())
  roomTypeId    String
  roomType      HostelRoomType     @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  roomNumber    String             @unique
  block         String             @default("")
  floor         String             @default("")
  capacity      Int
  occupiedBeds  Int                @default(0)
  status        String             @default("AVAILABLE")
  notes         String?            @default("")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  allocations   HostelAllocation[]
}

model HostelFeeStructure {
  id                 String             @id @default(uuid())
  roomTypeId         String
  roomType           HostelRoomType     @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  academicYear       String
  term               String
  billingCycle       String             @default("monthly")
  amount             Float
  cautionDeposit     Float              @default(0)
  messCharge         Float              @default(0)
  maintenanceCharge  Float              @default(0)
  notes              String?            @default("")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  allocations        HostelAllocation[]
}

model HostelAllocation {
  id                    String               @id @default(uuid())
  studentId             String
  student               Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  roomTypeId            String
  roomType              HostelRoomType       @relation(fields: [roomTypeId], references: [id])
  roomId                String
  room                  HostelRoom           @relation(fields: [roomId], references: [id])
  feeStructureId        String?
  feeStructure          HostelFeeStructure?  @relation(fields: [feeStructureId], references: [id])
  academicYear          String
  bedLabel              String               @default("")
  allotmentDate         DateTime             @default(now())
  vacatedOn             DateTime?
  status                String               @default("ACTIVE")
  guardianContactName   String               @default("")
  guardianContactPhone  String               @default("")
  notes                 String?              @default("")
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
}

model CanteenItem {
  id                String            @id @default(uuid())
  name              String
  price             Float
  quantityAvailable Int               @default(0)
  category          String?
  isAvailable       Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  saleItems         CanteenSaleItem[]
}

model CanteenSale {
  id          String            @id @default(uuid())
  total       Float
  paymentMode String            @default("Cash")
  soldTo      String?
  soldById    String?
  soldBy      User?             @relation("CanteenSoldBy", fields: [soldById], references: [id])
  date        DateTime          @default(now())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  items       CanteenSaleItem[]
}

model CanteenSaleItem {
  id       String       @id @default(uuid())
  saleId    String
  sale      CanteenSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  itemId    String?
  item      CanteenItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)
  quantity  Int
  price     Float?
}

model AuditLog {
  id         String   @id @default(uuid())
  userId      String
  user        User     @relation("AuditUser", fields: [userId], references: [id], onDelete: Cascade)
  action      String
  module      String
  recordId    String?
  oldValue    Json?
  newValue    Json?
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, timestamp])
  @@index([module, timestamp])
  @@index([action, timestamp])
  @@index([timestamp])
}

model Counter {
  id         String   @id @default(uuid())
  name       String
  year       Int
  sequence   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([name, year])
}

model ChatbotLog {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation("ChatbotUser", fields: [userId], references: [id], onDelete: Cascade)
  userRole     String   @default("unknown")
  message      String
  language     String   @default("en")
  intent       String   @default("None")
  response     String?  @db.Text
  responseTime Int      @default(0)
  timestamp    DateTime @default(now())
  sessionId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([intent, timestamp])
  @@index([userId, timestamp])
  @@index([timestamp])
}
