# Server Configuration
PORT=5000
NODE_ENV=development

# Database (Prisma)
DATABASE_URL=mysql://root:@localhost:3306/school_erp
DATABASE_URL_TEST=mysql://root:@localhost:3306/school_erp_test

# JWT Configuration
JWT_SECRET=
JWT_EXPIRES_IN=7d
ALLOW_RESET_TOKEN_PREVIEW=false
RATE_LIMIT_SKIP_LOCALHOST=false

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# School Information
SCHOOL_NAME=St. Xavier's School
SCHOOL_ADDRESS=
SCHOOL_PHONE=
SCHOOL_EMAIL=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Email Configuration (Optional - for future use)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Payment Gateway (Optional - for future use)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Logging
LOG_LEVEL=info
