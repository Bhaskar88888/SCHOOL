# School ERP PHP v3.0 - Enhanced Security .htaccess
# Apache Configuration with Security Hardening

# Disable directory listing
Options -Indexes

# Enable rewrite engine
RewriteEngine On
RewriteBase /

# ============================================
# SECURITY HEADERS
# ============================================

# Prevent clickjacking
Header always set X-Frame-Options "DENY"

# Prevent MIME type sniffing
Header always set X-Content-Type-Options "nosniff"

# Enable XSS protection
Header always set X-XSS-Protection "1; mode=block"

# Referrer policy
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# Content Security Policy (adjust as needed)
Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self';"

# HSTS (enable after testing with HTTPS)
# Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

# ============================================
# PROTECT SENSITIVE FILES
# ============================================

# Block access to config, includes, tmp directories
<DirectoryMatch "^/.*/(config|includes|tmp|tests)/">
    Require all denied
</DirectoryMatch>

# Block access to .env files
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

# Block access to .git
<DirectoryMatch "^/.*/\.git/">
    Require all denied
</DirectoryMatch>

# Block access to SQL files
<FilesMatch "\.sql$">
    Require all denied
</FilesMatch>

# Block access to backup files
<FilesMatch "\.(bak|backup|old|tmp)$">
    Require all denied
</FilesMatch>

# Block access to log files
<FilesMatch "\.log$">
    Require all denied
</FilesMatch>

# ============================================
# PHP SECURITY SETTINGS
# ============================================

# Disable PHP execution in uploads directory
<Directory "uploads">
    php_flag engine off
    <FilesMatch "\.php$">
        Require all denied
    </FilesMatch>
</Directory>

# File size limits
LimitRequestBody 5242880

# ============================================
# CLEAN URLS (Optional - for pretty URLs)
# ============================================

# Remove .php extension (optional)
# RewriteCond %{REQUEST_FILENAME} !-d
# RewriteCond %{REQUEST_FILENAME}\.php -f
# RewriteRule ^(.*)$ $1.php [L]

# ============================================
# COMPRESSION
# ============================================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# ============================================
# BROWSER CACHING
# ============================================

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 month"
</IfModule>

# ============================================
# DEFAULT INDEX
# ============================================

DirectoryIndex index.php index.html

# ============================================
# ERROR HANDLING
# ============================================

ErrorDocument 404 /404.php
ErrorDocument 403 /403.php
ErrorDocument 500 /500.php
