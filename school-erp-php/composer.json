{
    "name": "eduglass/school-erp-php",
    "description": "Comprehensive School Management System built with PHP",
    "type": "project",
    "license": "MIT",
    "version": "3.0.0",
    "require": {
        "php": ">=7.4",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-mbstring": "*",
        "ext-json": "*",
        "ext-fileinfo": "*",
        "ext-openssl": "*",
        "ext-zip": "*",
        "ext-gd": "*",
        "ext-curl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "files": [
            "config/env.php",
            "includes/db.php",
            "includes/auth.php",
            "includes/validator.php",
            "includes/api_response.php",
            "includes/helpers.php",
            "includes/cache.php",
            "includes/secure_upload.php",
            "includes/rate_limiter.php",
            "includes/audit_logger.php",
            "includes/env_loader.php",
            "includes/csrf.php"
        ]
    },
    "scripts": {
        "test": "phpunit tests/",
        "setup": "php -r \"require 'includes/env_loader.php'; echo 'Environment loaded.\\n';\"",
        "backup": "php scripts/backup-db.php",
        "backup-list": "php scripts/backup-db.php --list",
        "backup-cleanup": "php scripts/backup-db.php --cleanup"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
